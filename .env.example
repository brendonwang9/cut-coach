# ============================================================
# CUT COACH SYNC - Environment Variables
# ============================================================
# Copy this to .env and fill in your values

# JEFIT Session Cookie
# How to get: Open browser DevTools → Application → Cookies → jefit.com
# Copy the full cookie string (or just the session/auth cookies)
JEFIT_SESSION_COOKIE=your_session_cookie_here
JEFIT_USER_ID=10835027

# Notion Integration
# How to get: https://www.notion.so/my-integrations → Create integration → Copy token
# Then share your Cut Coach databases with the integration
NOTION_API_KEY=ntn_your_key_here

# Database IDs (already filled from your workspace - update if they change)
NOTION_WORKOUTS_DB=1224293308dd46ef904212d29e141e04
NOTION_EXERCISE_LOGS_DB=0ba489f819af4109abf1f9281ba60680
NOTION_BODY_METRICS_DB=18c8a9a691324540ae20a0dc6d3532f0
NOTION_ALERTS_DB=ea9b74179f6a4075a23084e08c9770bc

# Google Sheets API Key (read-only access)
# How to get: Google Cloud Console → APIs → Credentials → Create API Key
# Enable Google Sheets API for your project
GOOGLE_SHEETS_API_KEY=your_api_key_here
GOOGLE_SHEET_ID=1wqtSD9IpYRV-qsrj_5HNmqBHJrduFGeF6gtYmyTFPuI
